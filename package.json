{
    "name": "Kone-Kids",
    "version": "0.0.0",
    "homepage": "https://kids.koneacademy.io",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "postbuild": "react-snap || echo 'Pre-rendering timed out, deploying SPA...'",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d dist --dotfiles -f",
        "postinstall": "node patch-react-snap.cjs",
        "cap:copy": "cap copy",
        "cap:sync": "cap sync",
        "cap:open:android": "cap open android"
    },
    "dependencies": {
        "@capacitor/android": "^8.4.2",
        "@capacitor/core": "^8.4.2",
        "@capacitor/haptics": "^8.0.2",
        "@emailjs/browser": "^4.4.1",
        "blockly": "^12.5.1",
        "canvas-confetti": "^1.9.4",
        "firebase": "^12.12.1",
        "i18next": "^23.16.8",
        "i18next-browser-languagedetector": "^8.2.1",
        "lucide-react": "^1.14.0",
        "prismjs": "^1.30.0",
        "react": "^17.0.0",
        "react-dom": "^17.0.0",
        "react-i18next": "^13.5.0",
        "react-router-dom": "^6.30.3"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.4.2",
        "@types/canvas-confetti": "^1.9.0",
        "@types/react": "^17.0.0",
        "@types/react-dom": "^17.0.0",
        "gh-pages": "^6.3.0",
        "react-snap": "^1.23.0",
        "typescript": "^4.1.2",
        "vite": "^1.0.0-rc.13",
        "vite-plugin-react": "^4.0.0"
    },
    "reactSnap": {
        "source": "dist",
        "navigationOptions": {
            "timeout": 120000
        },
        "puppeteerArgs": [
            "--no-sandbox",
            "--disable-setuid-sandbox"
        ]
    },
    "overrides": {
        "react-snap": {
            "puppeteer": "^22.0.0"
        }
    }
}
